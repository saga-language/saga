// Verify Map.Equals: order-independent key/value comparison.
import "std/io"

pub fn Main() Void {
  a := {"x": 1, "y": 2}
  b := {"y": 2, "x": 1}    // same content, different insertion order
  c := {"x": 1, "y": 3}    // different value
  d := {"x": 1}            // different size

  io.Println(a.Equals(b).String())
  io.Println(a.Equals(c).String())
  io.Println(a.Equals(d).String())
  io.Println(a.Equals(a).String())
}

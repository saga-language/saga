// Spec: a wider interface is compatible with a narrower one (subset).
// (docs/language.md:961-964)
import "std/io"

interface Reader {
  Read() String
}
interface Closer {
  Close() Void
}

const ReadCloser = Reader | Closer

struct File {
  pub fn Read() String { "lines" }
  pub fn Close() Void {}
}

fn ReadOnly(r Reader) Void {
  io.Println(r.Read())
}

pub fn Main() Void {
  rc ReadCloser = File{}
  ReadOnly(rc)
}

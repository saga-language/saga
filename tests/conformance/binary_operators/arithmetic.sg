// Spec: + - * / ** % arithmetic operators. (docs/language.md:1377-1378)
import "std/io"

pub fn Main() Void {
  io.Println((3 + 4).String())
  io.Println((10 - 3).String())
  io.Println((6 * 7).String())
  div := 20 / 4 or { 0 }
  io.Println(div.String())
  io.Println((2 ** 10).String())
  rem := 17 % 5 or { 0 }
  io.Println(rem.String())
}

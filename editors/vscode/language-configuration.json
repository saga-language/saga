{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    {
      "open": "\"",
      "close": "\"",
      "notIn": ["string", "comment"]
    }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "autoCloseBefore": ";:.,=}])>` \n\t",
  "indentationRules": {
    "increaseIndentPattern": "\\{\\s*(//.*)?$",
    "decreaseIndentPattern": "^\\s*\\}"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*\\??",
  "folding": {
    "markers": {
      "start": "\\{\\s*(//.*)?$",
      "end": "^\\s*\\}"
    }
  },
  "onEnterRules": [
    {
      "beforeText": "\\{\\s*(//.*)?$",
      "action": {
        "indent": "indent"
      }
    }
  ]
}

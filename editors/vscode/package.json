{
  "name": "saga-language",
  "displayName": "Saga",
  "description": "Syntax highlighting, language support, and LSP integration for the Saga programming language (.sg)",
  "version": "0.1.0",
  "publisher": "saga",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saga-lang/saga"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:saga"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "saga",
        "aliases": [
          "Saga",
          "saga"
        ],
        "extensions": [
          ".sg"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/saga-light.png",
          "dark": "./icons/saga-dark.png"
        }
      }
    ],
    "commands": [
      {
        "command": "saga.showOutput",
        "title": "Saga: Show Language Server Output"
      }
    ],
    "grammars": [
      {
        "language": "saga",
        "scopeName": "source.saga",
        "path": "./syntaxes/saga.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}

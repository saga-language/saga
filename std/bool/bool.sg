// Package bool provides methods on the Bool intrinsic type.
// This is a stdlib package compiled with --stdlib; do not import directly.

extern fn saga_bool_to_string(b Bool) String
extern fn saga_bool_hash(b Bool) Int64

pub fn (b Bool) String() String {
  saga_bool_to_string(b)
}

pub fn (b Bool) Equals(other Bool) Bool {
  b == other
}

pub fn (b Bool) Hash() Int64 {
  saga_bool_hash(b)
}
